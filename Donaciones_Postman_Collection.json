{
	"info": {
		"name": "Donaciones API (UNAD)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Registro",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.token) pm.collectionVariables.set('token', res.token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nombre\": \"Juan Perez\",\n    \"correo\": \"juan@example.com\",\n    \"password\": \"123456\",\n    \"telefono\": \"+57 300 1234567\",\n    \"direccion\": \"Calle 123\",\n    \"tipo_usuario\": \"donador\"\n}"
						},
						"url": { "raw": "http://localhost:8000/auth/registro", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["auth", "registro"] }
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.token) pm.collectionVariables.set('token', res.token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"correo\": \"juan@example.com\",\n    \"password\": \"123456\"\n}"
						},
						"url": { "raw": "http://localhost:8000/auth/login", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["auth", "login"] }
					}
				}
			]
		},
		{
			"name": "Usuarios",
			"item": [
				{
					"name": "Get All Usuarios",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": { "raw": "http://localhost:8000/usuarios", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["usuarios"] }
					}
				},
