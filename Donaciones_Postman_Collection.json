						"url": { "raw": "http://localhost:8000/usuarios/:id", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["usuarios", ":id"], "variable": [{ "key": "id", "value": "" }] }
					}
				},
				{
					"name": "Delete Usuario",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
